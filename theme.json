{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#F8F9FA",
					"name": "Base Alt",
					"slug": "base-alt"
				},
				{
					"color": "#1A1A2E",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#6B7280",
					"name": "Contrast Muted",
					"slug": "contrast-muted"
				},
				{
					"color": "#4F46E5",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#4338CA",
					"name": "Accent Hover",
					"slug": "accent-hover"
				},
				{
					"color": "#EEF2FF",
					"name": "Accent Subtle",
					"slug": "accent-subtle"
				},
				{
					"color": "#FFFFFF",
					"name": "Surface",
					"slug": "surface"
				},
				{
					"color": "#E5E7EB",
					"name": "Border",
					"slug": "border"
				},
				{
					"color": "#F3F4F6",
					"name": "Border Subtle",
					"slug": "border-subtle"
				}
			]
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"slug": "sm",
					"shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)"
				},
				{
					"name": "Medium",
					"slug": "md",
					"shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)"
				},
				{
					"name": "Large",
					"slug": "lg",
					"shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
				}
			]
		},
		"layout": {
			"contentSize": "960px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "4px",
					"slug": "2-xs"
				},
				{
					"name": "X-Small",
					"size": "8px",
					"slug": "xs"
				},
				{
					"name": "Small",
					"size": "12px",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"size": "16px",
					"slug": "md"
				},
				{
					"name": "Large",
					"size": "24px",
					"slug": "lg"
				},
				{
					"name": "X-Large",
					"size": "32px",
					"slug": "xl"
				},
				{
					"name": "2X-Large",
					"size": "clamp(2rem, 1.5rem + 2vw, 3rem)",
					"slug": "2-xl"
				},
				{
					"name": "3X-Large",
					"size": "clamp(3rem, 2rem + 3vw, 5rem)",
					"slug": "3-xl"
				},
				{
					"name": "4X-Large",
					"size": "clamp(4rem, 3rem + 4vw, 7rem)",
					"slug": "4-xl"
				}
			]
		},
		"typography": {
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": true,
			"lineHeight": true,
			"fontSizes": [
				{
					"name": "Extra Small",
					"size": "13px",
					"slug": "xs"
				},
				{
					"name": "Small",
					"size": "15px",
					"slug": "sm"
				},
				{
					"name": "Base",
					"size": "17px",
					"slug": "base"
				},
				{
					"name": "Medium",
					"size": "20px",
					"slug": "md"
				},
				{
					"name": "Large",
					"size": "24px",
					"slug": "lg"
				},
				{
					"name": "X-Large",
					"size": "32px",
					"slug": "xl"
				},
				{
					"name": "2X-Large",
					"size": "clamp(2.25rem, 2rem + 1vw, 2.625rem)",
					"slug": "2-xl"
				},
				{
					"name": "3X-Large",
					"size": "clamp(2.5rem, 2rem + 2vw, 3.25rem)",
					"slug": "3-xl"
				}
			],
			"fontFamilies": [
				{
					"name": "Plus Jakarta Sans",
					"slug": "plus-jakarta-sans",
					"fontFamily": "'Plus Jakarta Sans', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "200 800",
							"fontStyle": "normal",
							"src": [
								"file:./assets/fonts/PlusJakartaSans/PlusJakartaSans-Variable.woff2"
							]
						},
						{
							"fontFamily": "Plus Jakarta Sans",
							"fontWeight": "200 800",
							"fontStyle": "italic",
							"src": [
								"file:./assets/fonts/PlusJakartaSans/PlusJakartaSans-Italic-Variable.woff2"
							]
						}
					]
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"padding": {
				"left": "var:preset|spacing|lg",
				"right": "var:preset|spacing|lg"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|plus-jakarta-sans",
			"fontSize": "var:preset|font-size|base",
			"lineHeight": "1.6",
			"fontWeight": "400"
		},
		"blocks": {
			"core/button": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontWeight": "600"
				},
				"border": {
					"radius": "8px"
				},
				"color": {
					"text": "var:preset|color|base",
					"background": "var:preset|color|accent"
				},
				"spacing": {
					"padding": {
						"top": "12px",
						"bottom": "12px",
						"left": "24px",
						"right": "24px"
					}
				}
			}
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var:preset|color|contrast"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|plus-jakarta-sans",
					"fontWeight": "700"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|3-xl",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"lineHeight": "1.25"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|lg",
					"lineHeight": "1.3"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|md",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"lineHeight": "1.5"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|accent"
				},
				"typography": {
					"textDecoration": "underline",
					"textDecorationThickness": "1px"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|accent-hover"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "header",
			"name": "header-large-title",
			"title": "Header with large title"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "footer",
			"name": "footer-columns",
			"title": "Footer Columns"
		},
		{
			"area": "footer",
			"name": "footer-newsletter",
			"title": "Footer Newsletter"
		},
		{
			"area": "uncategorized",
			"name": "sidebar",
			"title": "Sidebar"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"postTypes": [
				"page"
			],
			"title": "Page No Title"
		}
	]
}
